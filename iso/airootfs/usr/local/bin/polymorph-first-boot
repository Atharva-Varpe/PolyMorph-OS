#!/bin/bash
# PolyMorph First-Boot Wizard
# Runs once on first login to help users configure their new system.

set -euo pipefail
export PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

WIZARD_MARKER="/var/lib/polymorph/first-boot-complete"
LOG_FILE="/var/log/polymorph-first-boot.log"

if [ "$EUID" -eq 0 ]; then
    echo -e "${RED}Error: Do not run this wizard as root.${NC}"
    exit 1
fi

if [ -f "$WIZARD_MARKER" ]; then
    exit 0
fi

sudo mkdir -p "$(dirname "$LOG_FILE")" "$(dirname "$WIZARD_MARKER")"
sudo touch "$LOG_FILE"
sudo chmod 600 "$LOG_FILE"

log() { echo "[$(date '+%Y-%m-%d %H:%M:%S')] $*" | sudo tee -a "$LOG_FILE" >/dev/null; }

ask_yn() {
    local question="$1" default="${2:-n}" prompt
    [ "$default" = "y" ] && prompt="[Y/n]" || prompt="[y/N]"
    while true; do
        read -r -p "$question $prompt " resp
        resp="${resp:-$default}"
        case "$resp" in
            [Yy]*) return 0 ;;
            [Nn]*) return 1 ;;
            *) echo "Please answer yes or no." ;;
        esac
    done
}

valid_pkg() { [[ "$1" =~ ^[a-zA-Z0-9._+-]+$ ]]; }

log "First-boot wizard started by user: $USER"
echo -e "${BLUE}╔════════════════════════════════════════════════════════╗${NC}"
echo -e "${BLUE}║          Welcome to PolyMorph Linux! 🎉                ║${NC}"
echo -e "${BLUE}╚════════════════════════════════════════════════════════╝${NC}"
echo ""

# ── 1. System Update ──────────────────────────────────────────────────────
echo -e "${GREEN}[1/4] System Update${NC}"
if ask_yn "Update system packages now?" "y"; then
    log "Starting system update"
    if sudo pacman -Syu --noconfirm 2>&1 | sudo tee -a "$LOG_FILE" >/dev/null; then
        echo -e "${GREEN}✓ System updated${NC}"
        log "System update complete"
    else
        echo -e "${YELLOW}⚠ Update failed — see $LOG_FILE${NC}"
        log "System update failed"
    fi
else
    echo "Skipped. Run: sudo pacman -Syu"
    log "System update skipped"
fi
echo ""

# ── 2. Network ────────────────────────────────────────────────────────────
echo -e "${GREEN}[2/4] Network${NC}"
if ! systemctl is-enabled NetworkManager &>/dev/null; then
    if ask_yn "Enable NetworkManager?" "y"; then
        sudo systemctl enable --now NetworkManager
        echo -e "${GREEN}✓ NetworkManager enabled${NC}"
        log "NetworkManager enabled"
    fi
else
    echo "NetworkManager is already enabled."
fi
echo ""

# ── 3. Optional Software ──────────────────────────────────────────────────
echo -e "${GREEN}[3/4] Optional Software${NC}"
declare -A APPS=(
    [firefox]="Firefox browser"
    [vlc]="VLC media player"
    [libreoffice-fresh]="LibreOffice suite"
    [git]="Git version control"
    [base-devel]="Development tools"
)
INSTALL=()
for pkg in "${!APPS[@]}"; do
    if ask_yn "  Install ${APPS[$pkg]}?" "n"; then
        INSTALL+=("$pkg")
    fi
done

if [ ${#INSTALL[@]} -gt 0 ]; then
    VALID=()
    for pkg in "${INSTALL[@]}"; do
        if valid_pkg "$pkg"; then
            VALID+=("$pkg")
        else
            echo -e "${YELLOW}⚠ Skipping invalid package: $pkg${NC}"
            log "SECURITY: rejected package name: $pkg"
        fi
    done
    if [ ${#VALID[@]} -gt 0 ]; then
        log "Installing: ${VALID[*]}"
        if sudo pacman -S --noconfirm "${VALID[@]}" 2>&1 | sudo tee -a "$LOG_FILE" >/dev/null; then
            echo -e "${GREEN}✓ Installed: ${VALID[*]}${NC}"
            log "Package install complete"
        else
            echo -e "${YELLOW}⚠ Some packages failed — see $LOG_FILE${NC}"
            log "Package install had errors"
        fi
    fi
fi
echo ""

# ── 4. User Groups ────────────────────────────────────────────────────────
echo -e "${GREEN}[4/4] User Groups${NC}"
if ask_yn "Add $USER to wheel, audio, video, storage?" "y"; then
    if [[ "$USER" =~ ^[a-z_][a-z0-9_-]*$ ]]; then
        sudo usermod -aG wheel,audio,video,storage,optical "$USER"
        echo -e "${GREEN}✓ Groups updated (re-login to apply)${NC}"
        log "User $USER added to groups"
    else
        echo -e "${RED}Error: unexpected username, skipping.${NC}"
        log "SECURITY: unexpected username rejected: $USER"
    fi
fi
echo ""

# ── Summary ───────────────────────────────────────────────────────────────
sudo mkdir -p /var/lib/polymorph
sudo tee /var/lib/polymorph/install-summary.txt >/dev/null <<EOF
PolyMorph Installation Summary
===============================
Date:    $(date)
Kernel:  $(uname -r)
Desktop: ${XDG_CURRENT_DESKTOP:-unknown}
User:    $USER
Host:    $(hostname)
EOF

sudo touch "$WIZARD_MARKER"
log "First-boot wizard complete"

echo -e "${BLUE}╔════════════════════════════════════════════════════════╗${NC}"
echo -e "${BLUE}║          Setup Complete! Enjoy PolyMorph Linux ✓       ║${NC}"
echo -e "${BLUE}╚════════════════════════════════════════════════════════╝${NC}"
echo ""
echo "  Update:   sudo pacman -Syu"
echo "  Install:  sudo pacman -S <package>"
echo "  Search:   pacman -Ss <keyword>"
echo ""
read -rp "Press Enter to continue…"
